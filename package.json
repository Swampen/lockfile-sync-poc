{
  "name": "lockfile-sync-poc",
  "private": true,
  "packageManager": "npm@11.5.2",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "install:lockfile": "npm install --package-lock-only --ignore-scripts"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
